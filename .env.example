# Google Gemini API (for embeddings)
# Get free key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Groq API (for LLM - free tier)
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# MongoDB
# Local: mongodb://localhost:27017
# Atlas free tier: mongodb+srv://<user>:<pass>@cluster.mongodb.net
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=customer_support

# Gmail SMTP (for email notifications)
# Use a Gmail address + App Password (requires 2FA enabled)
# Generate App Password at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Developer/support team email (receives ticket assignment alerts)
DEVELOPER_EMAIL=support_team@company.com
